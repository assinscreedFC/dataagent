# dataagent — environment variables
# Copy to .env and fill in your own values. Never commit .env.

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Model names (optional — sensible defaults applied if left empty)
GEMINI_MODEL_FLASH=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
